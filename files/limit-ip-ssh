#!/bin/bash

# Load Bot Config Sekali Saja
CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
URL="https://api.telegram.org/bot$KEY/sendMessage"

function send-log(){
    local user=$1
    local limit=$2
    local login=$3
    local TEXT="
<code>☉────────────────────☉</code>
<b>⚠️ MULTILOGIN SSH DETECTED ⚠️</b>
<code>☉────────────────────☉</code>
<code>Username :</code> <code>$user</code>
<code>Limit IP :</code> <code>$limit</code>
<code>Login IP :</code> <code>$login</code>
<code>Action   :</code> <code>User Locked</code>
<code>☉────────────────────☉</code>"
    curl -s --max-time 10 -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
}

# Tentukan Log
[ -f /var/log/auth.log ] && LOG="/var/log/auth.log" || LOG="/var/log/secure"
if [ ! -f "$LOG" ]; then exit 1; fi

# Ambil snapshot data login SSH & Dropbear sekaligus (Efisien)
# Menggunakan netstat/ss jauh lebih akurat daripada grep log lama
login_data=$(netstat -tnpa | grep -E 'sshd|dropbear' | grep ESTABLISHED)

# Ambil daftar user yang punya setting limit
users=$(ls /etc/kyt/limit/ssh/ip/)

locked_any=0

for user in $users; do
    MAX=$(cat /etc/kyt/limit/ssh/ip/$user)
    [[ $MAX =~ ^[0-9]+$ ]] || MAX=999
    
    # Hitung jumlah login user tersebut dari snapshot data (Sangat Cepat)
    # Mencari username di kolom terakhir netstat
    count=$(echo "$login_data" | grep -w "$user" | wc -l)
    
    if [ "$count" -gt "$MAX" ] && [ "$MAX" -ne 0 ]; then
        echo "$(date) - Locking $user ($count/$MAX)"
        
        # Lock user agar tidak bisa login lagi
        passwd -l "$user"
        
        # Kill semua proses milik user tersebut agar koneksi terputus
        pkill -u "$user"
        
        send-log "$user" "$MAX" "$count"
        locked_any=1
    fi
done

# Restart service hanya sekali jika ada yang di-lock
if [ "$locked_any" -eq 1 ]; then
    systemctl restart ssh >/dev/null 2>&1
    systemctl restart dropbear >/dev/null 2>&1
fi
