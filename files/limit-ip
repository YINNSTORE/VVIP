#!/bin/bash

# Load Bot Data sekali saja di awal
CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
URL="https://api.telegram.org/bot$KEY/sendMessage"

function send_log(){
    local user=$1
    local iplimit=$2
    local TIME="10"
    local TEXT="
<code>────────────────────</code>
<b>⚠️ NOTIFICATIONS MULTI LOGIN ⚠️</b>
<code>────────────────────</code>
<code>Username  : </code><code>$user</code>
<code>Limit Ip  : </code><code>$iplimit</code>
<code>Action    : </code><code>User Deleted</code>
<code>────────────────────</code>"
    curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" $URL >/dev/null
}

# Variable untuk cek apakah butuh restart xray
NEED_RESTART=0
LOG_FILE="/var/log/xray/access.log"

function process_limit() {
    local type=$1 # vmess, vless, atau trojan
    local prefix=$2 # ###, #&, atau #!
    local db_file=$3
    
    if [ ! -d "/etc/kyt/limit/$type/ip" ]; then return; fi
    
    # Ambil snapshot log agar tidak berubah saat proses
    local log_content=$(cat "$LOG_FILE")
    
    data=( $(ls "/etc/kyt/limit/$type/ip") )
    for user in "${data[@]}"; do
        iplimit=$(cat "/etc/kyt/limit/$type/ip/$user")
        # Grep langsung dari snapshot memori (jauh lebih cepat)
        cekcek=$(echo "$log_content" | grep -w "$user" | cut -d " " -f 3 | sed 's/tcp://g' | cut -d ":" -f 1 | sort | uniq | wc -l)
        
        if [[ $cekcek -gt $iplimit ]]; then
            exp=$(grep -w "^$prefix $user" "/etc/xray/config.json" | cut -d ' ' -f 3 | head -n1)
            if [ ! -z "$exp" ]; then
                # Hapus user dari config
                sed -i "/^$prefix $user $exp/,/^},{/d" /etc/xray/config.json
                sed -i "/^$prefix $user $exp/d" "$db_file"
                rm -rf "/etc/kyt/limit/$type/ip/$user"
                
                send_log "$user" "$iplimit"
                NEED_RESTART=1
            fi
        fi
        sleep 0.1
    done
}

# Main Logic
case "${1}" in
    vmip)
        process_limit "vmess" "###" "/etc/vmess/.vmess.db"
        ;;
    vlip)
        process_limit "vless" "#&" "/etc/vless/.vless.db"
        ;;
    trip)
        process_limit "trojan" "#!" "/etc/trojan/.trojan.db"
        ;;
esac

# Restart Xray HANYA SEKALI jika ada perubahan
if [[ $NEED_RESTART -eq 1 ]]; then
    systemctl restart xray
    # Kosongkan log HANYA setelah restart agar fresh
    echo -n > "$LOG_FILE"
fi
